{{ if (or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin")) -}}
#!/bin/bash

{{ if eq .chezmoi.os "linux" -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

if command -v brew &> /dev/null; then
    echo "Installing packages via Homebrew..."
    brew install neovim git node eza ripgrep fd zoxide wget zsh python unzip gcc gnupg
else
    echo "Homebrew not found. Run install.sh first."
    exit 1
fi

if [ ! -d "$HOME/.oh-my-zsh" ]; then
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

if [ "$SHELL" != "$(which zsh)" ]; then
    ZSH_PATH="$(which zsh)"
    if ! grep -qxF "$ZSH_PATH" /etc/shells; then
        echo "$ZSH_PATH" | sudo tee -a /etc/shells
    fi
    sudo chsh -s "$ZSH_PATH" "$USER"
fi

FONT_DIR="{{ if eq .chezmoi.os "darwin" }}$HOME/Library/Fonts{{ else }}$HOME/.local/share/fonts{{ end }}"
if [ ! -d "$FONT_DIR/JetBrainsMono" ]; then
    echo "Installing JetBrains Mono Nerd Font..."
    mkdir -p "$FONT_DIR/JetBrainsMono"
    wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip -P /tmp
    unzip /tmp/JetBrainsMono.zip -d "$FONT_DIR/JetBrainsMono"
    {{ if eq .chezmoi.os "linux" }}fc-cache -fv{{ end }}
fi

if [ ! -d "$HOME/.config/nvim" ]; then
    echo "Installing NvChad..."
    git clone https://github.com/NvChad/starter ~/.config/nvim
fi

echo "Setup complete."
{{ end -}}

{{ if eq .chezmoi.os "windows" -}}
Write-Host "Windows setup complete."
{{ end -}}
