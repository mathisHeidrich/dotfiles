if [ -d /home/linuxbrew/.linuxbrew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -d /opt/homebrew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export ZSH="$HOME/.oh-my-zsh"
export PATH="$HOME/.rbenv/shims:$PATH"
export PATH="/opt/flutter/bin:$PATH"
export PATH="/opt/android-studio/bin:$PATH"
export PATH="$HOME/.composer/vendor/bin:$PATH"
export PATH="$HOME/.spicetify:$PATH"
export PATH="$HOME/.jenv/bin:$PATH"
export GCM_CREDENTIAL_STORE="gpg"
export GPG_TTY=$(tty)
export EDITOR='nvim'
export VISUAL='nvim'
if command -v rbenv &> /dev/null; then
    eval "$(rbenv init -)"
fi

if command -v jenv &> /dev/null; then
    eval "$(jenv init -)"
fi
eval "$(zoxide init zsh)"

zstyle :omz:plugins:ssh-agent lazy yes
zstyle :omz:plugins:ssh-agent helper yes

ZSH_THEME="dieter"
HYPHEN_INSENSITIVE="true"
DISABLE_AUTO_UPDATE="true"
ENABLE_CORRECTION="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
plugins=(
  git
  autopep8
  dotenv
  emoji
  z
  pip
  python
  sudo
  vundle
  rbenv
  virtualenv
  ssh-agent
)

source $ZSH/oh-my-zsh.sh

alias ls="eza --header --long --time-style=long-iso --group-directories-first --git --icons"
alias cp="cp -r"
alias vim="nvim"
alias bluere="sudo launchctl stop com.apple.bluetoothd; sudo launchctl start com.apple.bluetoothd"

unsetopt correct_all

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
